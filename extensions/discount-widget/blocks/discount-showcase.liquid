<div 
  class="discount-showcase-container" 
  data-shop="{{ shop.permanent_domain }}"
  data-campaign-id="{{ block.settings.campaign_id }}"
  data-show-countdown="{{ block.settings.show_countdown }}"
  data-show-stage-label="{{ block.settings.show_stage_label }}"
  data-items-per-row="{{ block.settings.items_per_row }}"
>
  <!-- Active campaign products will be rendered here dynamically via JS -->
  <div class="discount-showcase-loading">Loading promotional products...</div>
</div>

<!-- Modal Structure for View Details (Pure HTML/CSS/JS) -->
<div id="discount-product-modal" class="discount-modal">
  <div class="discount-modal-content">
    <span class="discount-modal-close">&times;</span>
    <div class="discount-modal-body">
      <div class="discount-modal-media">
        <img id="modal-product-image" src="" alt="Product Image">
      </div>
      <div class="discount-modal-info">
        <h2 id="modal-product-title">Product Title</h2>
        
        <div class="discount-modal-prices">
          <span id="modal-discounted-price" class="sale-price">$0.00</span>
          <span id="modal-original-price" class="original-price">$0.00</span>
        </div>

        <div id="modal-stage-badge" class="discount-stage-badge"></div>
        
        <div id="modal-countdown" class="discount-countdown-timer"></div>
        
        <p id="modal-product-description" class="discount-product-desc">Loading description...</p>

        <form id="modal-add-to-cart-form">
          <input type="hidden" id="modal-variant-id" name="id" value="">
          <div class="discount-quantity-selector">
            <label for="modal-quantity">Quantity:</label>
            <input type="number" id="modal-quantity" name="quantity" value="1" min="1">
          </div>
          <button type="submit" id="modal-submit-btn" class="discount-add-to-cart-btn">Add to Cart</button>
        </form>
      </div>
    </div>
  </div>
</div>

<link rel="stylesheet" href="{{ 'discount-showcase.css' | asset_url }}">
<script src="{{ 'discount-showcase.js' | asset_url }}" defer="defer"></script>


{% schema %}
{
  "name": "Discount Showcase",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "campaign_id",
      "label": "Campaign ID (Leave blank for active)",
      "default": "active"
    },

    {
      "type": "checkbox",
      "id": "show_countdown",
      "label": "Show Countdown",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_stage_label",
      "label": "Show Stage Label",
      "default": true
    },
    {
      "type": "select",
      "id": "items_per_row",
      "label": "Items Per Row",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "3"
    }
  ]
}
{% endschema %}

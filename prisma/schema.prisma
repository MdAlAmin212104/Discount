// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// datasource db {
//   provider = "postgresql"
//   url      = env("DATABASE_URL")
// }

datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Shop {
  id           String     @id @default(cuid())
  domain       String     @unique
  accessToken  String
  createdAt    DateTime   @default(now())
  campaigns    Campaign[]
  themeSettings ThemeSettings?
}

model Campaign {
  id          String           @id @default(cuid())
  shopId      String
  shop        Shop             @relation(fields: [shopId], references: [id])
  name        String
  status      CampaignStatus   @default(DRAFT)
  discountType DiscountType
  timezone    String           @default("UTC")
  startDate   DateTime
  endDate     DateTime
  notes       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  stages      CampaignStage[]
  products    CampaignProduct[]
  activityLogs ActivityLog[]
  priceSnapshots VariantPriceSnapshot[]
}

model CampaignStage {
  id           String   @id @default(cuid())
  campaignId   String
  campaign     Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  stageNumber  Int
  label        String?
  discountValue Float
  startDate    DateTime
  endDate      DateTime
  status       StageStatus @default(PENDING)
  shopifyDiscountId String?
}

model CampaignProduct {
  id           String   @id @default(cuid())
  campaignId   String
  campaign     Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  targetType   TargetType
  targetValue  String
}

model VariantPriceSnapshot {
  id          String   @id @default(cuid())
  shopId      String
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  variantId   String
  originalPrice Float
  originalComparePrice Float?
  currentPrice  Float
  snapshotAt  DateTime @default(now())

  @@unique([shopId, campaignId, variantId])
}

model ActivityLog {
  id         String      @id @default(cuid())
  shopId     String
  campaignId String?
  campaign   Campaign?   @relation(fields: [campaignId], references: [id])
  event      LogEvent
  message    String
  metadata   Json?
  createdAt  DateTime    @default(now())
}

model ThemeSettings {
  id              String  @id @default(cuid())
  shopId          String  @unique
  shop            Shop    @relation(fields: [shopId], references: [id])
  badgeText       String  @default("Sale")
  countdownText   String  @default("Ends in")
  stageLabelText  String  @default("Stage")
  fontSize        Int     @default(14)
  fontWeight      String  @default("500")
  salePriceColor  String  @default("#E63946")
  originalPriceColor String @default("#6B7280")
  badgeBg         String  @default("#E63946")
  badgeTextColor  String  @default("#FFFFFF")
  padding         Int     @default(12)
  borderRadius    Int     @default(8)
  alignment       String  @default("left")
  customJs        String  @default("")
  customCss       String  @default("")
  sliderItems     Int     @default(3)
  cartMode        String  @default("stay")
  memberLabel     String  @default("Inner Circle Member")
  welcomeHeading  String  @default("Exclusive Access")
  welcomeEmphasis String  @default("Offers")
  welcomeSubHeading String @default("Members get every release first, before public launch.")
  productHeading  String  @default("Selected Pieces")
  reserveButtonText String @default("Reserve Now")
  buttonAction    String  @default("cart")
  bgColor         String  @default("#f0efeb")
  textColor       String  @default("#0e0e0d")
  borderColor     String  @default("#e2dfd9")
  cardColor       String  @default("#faf9f7")
  accentColor     String  @default("#1a3a2a")
  mutedColor      String  @default("#9a9792")
  paddingTop      Int     @default(40)
  paddingBottom   Int     @default(40)
  maxWidth        Int     @default(580)
  conflictStrategy String @default("HIGHEST_DISCOUNT")
  publicShipping   String @default("Ships in ~5-7 days")
}


model SchedulerJob {
  id         String    @id @default(cuid())
  shopId     String
  stageId    String    @unique
  scheduledAt DateTime
  status     JobStatus @default(PENDING)
  attempts   Int       @default(0)
  lastError  String?
  processedAt DateTime?
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  COMPLETED
  PAUSED
}

enum DiscountType {
  PERCENTAGE
  FIX_AMOUNT
  FIXED_DISCOUNT
}

enum TargetType {
  PRODUCT
  COLLECTION
  TAG
}

enum StageStatus {
  PENDING
  ACTIVE
  COMPLETED
}

enum LogEvent {
  CAMPAIGN_CREATED
  CAMPAIGN_UPDATED
  STAGE_STARTED
  STAGE_COMPLETED
  PRICE_UPDATED
  PRICE_RESTORED
  CONFLICT_DETECTED
  SCHEDULER_ERROR
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}
